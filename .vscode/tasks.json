
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Assemble Z80",
      "type": "shell",
      "command": "/home/pi/sjasmplus/sjasmplus",
     // "command": "c:/sjasmplus-1.21.0.win/sjasmplus.exe",
      "args": [
        "${file}",
        "--raw=${fileDirname}/${fileBasenameNoExtension}.bin",
        "--lst=${fileDirname}/${fileBasenameNoExtension}.lst"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Upload ROM",
      "type": "process",
      "command": "python",
      "args": [
        "${workspaceFolder}/uploadRom.py",
        "${fileDirname}/asm/${fileBasenameNoExtension}.bin"
      ],
      "group": "build",
      "dependsOn": "Assemble Z80",
      "problemMatcher": []
    },   
    {
      "label": "Upload File to Z80",
      "type": "process",
      "command": "python",
      "args": [
        "${workspaceFolder}/uploadFile.py",
        "${fileDirname}/asm/${fileBasenameNoExtension}.bin"
      ],
      "group": "build",
      "dependsOn": "Assemble Z80",
      "problemMatcher": []
    }
  ]
}